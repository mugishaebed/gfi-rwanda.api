generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String                 @id @default(uuid())
  name                   String
  email                  String                 @unique
  clientOnboardingStatus ClientOnboardingStatus @default(ACTIVE)
  clientApprovedAt       DateTime?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  refreshTokenExpiresAt  DateTime?
  refreshTokenHash       String?
  roles                  UserRole[]             @default([LOAN_OFFICER])
  clientProfile          Client?
  identities             AuthIdentity[]
  loans                  Loan[]
}

model AuthIdentity {
  id             String       @id @default(uuid())
  userId         String
  provider       AuthProvider
  providerUserId String
  tenantId       String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@unique([userId, provider])
}

model Client {
  id            String            @id @default(uuid())
  type          ClientType
  email         String
  phoneNumber   String
  address       String
  accountNumber String            @unique
  userId        String?           @unique
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  business      BusinessClient?
  individual    IndividualClient?
  user          User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  loans         Loan[]
}

model IndividualClient {
  id                String   @id @default(uuid())
  clientId          String   @unique
  fullName          String
  nationalId        String   @unique
  gender            String
  dateOfBirth       DateTime
  nationality       String?
  maritalStatus     String?
  employerName      String?
  occupation        String?
  monthlyIncome     String?
  bankName          String?
  bankAccountNumber String?
  pep               Boolean?
  referenceName     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  client            Client   @relation(fields: [clientId], references: [id])
}

model BusinessClient {
  id                             String       @id @default(uuid())
  clientId                       String       @unique
  businessName                   String
  businessWebsite                String?
  pep                            Boolean
  registrationNumber             String       @unique
  businessType                   BusinessType
  incorporationDate              DateTime
  businessShareholders           Json
  bankName                       String?
  bankAccountNumber              String?
  authorizedSignatory            String?
  authorizedSignatoryDesignation String?
  annualRevenue                  String?
  createdAt                      DateTime     @default(now())
  updatedAt                      DateTime     @updatedAt
  client                         Client       @relation(fields: [clientId], references: [id])
}

model Loan {
  id                             String             @id @default(uuid())
  clientId                       String
  amount                         Float
  currency                       String             @default("RWF")
  totalRepaidAmount              Float              @default(0)
  outstandingBalance             Float
  purpose                        String
  repaymentTerms                 Json
  guarantorInfo                  Json?
  comments                       String?
  interestRatePercentPerMonth    Float
  termInMonths                   Int
  termStartDate                  DateTime           @db.Date
  termEndDate                    DateTime           @db.Date
  disbursementWithinDays         Int
  collateralType                 String
  collateralEstimatedValue       Float
  collateralLocation             String
  repaymentInstallmentsCount     Int
  repaymentAmountPerMonth        Float
  repaymentPeriodMonths          Int
  paymentDayOfMonth              Int
  loanProcessingFeePercent       Float
  administrativeFeePercent       Float
  loanApplicationFeePercent      Float
  earlyRepaymentFeePercent       Float
  defaultPenaltyFeePercentPerDay Float
  spouseName                     String?
  termsAccepted                  Boolean            @default(false)
  termsVersion                   String?
  disbursementMethod             DisbursementMethod @default(MOBILE_MONEY)
  disbursementReference          String?            @unique
  disbursedAmount                Float?
  disbursedAt                    DateTime?
  totalInterestExpected          Float?
  totalInterestReceived          Float              @default(0)
  totalPrincipalRecovered        Float              @default(0)
  source                         LoanSource         @default(STAFF_MANUAL)
  status                         LoanStatus         @default(PENDING)
  activatedAt                    DateTime?
  createdAt                      DateTime           @default(now())
  updatedAt                      DateTime           @updatedAt
  userId                         String?
  client                         Client             @relation(fields: [clientId], references: [id])
  user                           User?              @relation(fields: [userId], references: [id])
  statusLogs                     LoanStatusLog[]
  repayments                     Repayment[]

  @@index([source, status, createdAt])
}

model LoanStatusLog {
  id         String     @id @default(uuid())
  loanId     String
  fromStatus LoanStatus
  toStatus   LoanStatus
  changedBy  String
  note       String?
  createdAt  DateTime   @default(now())
  loan       Loan       @relation(fields: [loanId], references: [id])
}

model Repayment {
  id                 String                 @id @default(uuid())
  loanId             String
  amountPaid         Float
  principalPaid      Float?
  interestPaid       Float?
  paymentDate        DateTime
  notes              String?
  source             RepaymentSource        @default(STAFF_MANUAL)
  paymentProvider    OnlinePaymentProvider?
  paymentReference   String?                @unique
  paymentPhoneNumber String?
  status             RepaymentStatus        @default(PENDING)
  approvedAt         DateTime?
  createdAt          DateTime               @default(now())
  loan               Loan                   @relation(fields: [loanId], references: [id])

  @@index([source, status, createdAt])
  @@index([loanId, createdAt])
}

model Document {
  id               String            @id @default(uuid())
  ownerType        DocumentOwnerType
  ownerId          String
  label            String
  originalFileName String
  mimeType         String
  size             Int
  storageDriver    String
  storageKey       String
  uploadedByUserId String
  createdAt        DateTime          @default(now())

  @@index([ownerType, ownerId])
}

model Blog {
  id                        String        @id @default(uuid())
  title                     String
  shortDescription          String?
  author                    String
  contents                  BlogContent[]
  thumbnailStorageDriver    String?
  thumbnailStorageKey       String?
  thumbnailOriginalFileName String?
  thumbnailMimeType         String?
  thumbnailSize             Int?
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt
}

model BlogContent {
  id                    String   @id @default(uuid())
  blogId                String
  position              Int      @default(0)
  header                String?
  body                  String
  imageStorageDriver    String?
  imageStorageKey       String?
  imageOriginalFileName String?
  imageMimeType         String?
  imageSize             Int?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  blog Blog @relation(fields: [blogId], references: [id], onDelete: Cascade)

  @@index([blogId, position])
}

enum UserRole {
  LOAN_OFFICER
  GENERAL_MANAGER
  BLOG_EDITOR
  CLIENT
}

enum ClientOnboardingStatus {
  PENDING_PROFILE
  PENDING_APPROVAL
  ACTIVE
}

enum AuthProvider {
  MICROSOFT
  GOOGLE
}

enum ClientType {
  INDIVIDUAL
  BUSINESS
}

enum LoanStatus {
  PENDING
  LOAN_OFFICER_APPROVED
  LOAN_OFFICER_REJECTED
  APPROVED
  REJECTED
}

enum LoanSource {
  CLIENT_ONLINE
  STAFF_MANUAL
}

enum DisbursementMethod {
  MOBILE_MONEY
}

enum RepaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RepaymentSource {
  STAFF_MANUAL
  CLIENT_ONLINE
}

enum OnlinePaymentProvider {
  MOBILE_MONEY
}

enum DocumentOwnerType {
  CLIENT
  LOAN
  REPAYMENT
}

enum BusinessType {
  SOLE_PROPRIETORSHIP
  PARTNERSHIP
  LLC
}
